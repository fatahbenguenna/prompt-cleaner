<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>PromptCleaner.App</RootNamespace>
    <AssemblyName>prompt-cleaner</AssemblyName>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <!-- Permet de compiler le projet Windows depuis Linux/macOS (dev et CI). -->
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <!-- Pas de ressources satellites localisées : exe single-file plus léger. -->
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\PromptCleaner.Core\PromptCleaner.Core.csproj" />
  </ItemGroup>

</Project>
